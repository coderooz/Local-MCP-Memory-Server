# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/mcp_memory

# Server Configuration
# Use 0 for dynamic port allocation (recommended)
PORT=0

# MCP Project Identity
# Priority: .mcp-project file > MCP_PROJECT env > directory name
# MCP_AGENT=codex
MCP_PROJECT=local-mcp-server
MCP_SCOPE=project

# Node Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Reset System (for severe resets only)
# MCP_RESET_CONFIRM=<your-confirmation-code>
