# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{js,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.html]
indent_size = 2

[*.css]
indent_size = 2

[package.json]
indent_size = 2

[*.sh]
indent_size = 2
end_of_line = lf

[LICENSE]
insert_final_newline = false

[*.md]
trim_trailing_whitespace = false
